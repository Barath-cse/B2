PORT=5000
CORS_ORIGIN=http://localhost:3000
# Node Environment
NODE_ENV=development

# Blockchain Configuration (REQUIRED for gasless transactions)
# The private key must have enough ETH to pay for transactions
CONTRACT_ADDRESS=0xBCBf15C2899D62d6701A8294d88751E98512dec0
PRIVATE_KEY=your_private_key_without_0x_prefix

# Storage settings
UPLOAD_DIR=./uploads
CLEANUP_INTERVAL_HOURS=1
EXPIRY_DAYS=8

# --- RENDER DEPLOYMENT NOTES ---
# 1. Select 'Web Service' for backend
# 2. Build Command: npm install
# 3. Start Command: npm start
# 4. Add the above variables in 'Environment' section
